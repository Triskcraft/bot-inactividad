{
    "name": "bot-inactividad",
    "version": "1.0.0",
    "description": "Discord bot para gestionar periodos de inactividad y estadisticas de roles.",
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "start": "node src/index.ts",
        "lint": "eslint .",
        "build": "prisma generate && tsc",
        "dev": "node --watch src/index.ts",
        "db:copy-prod": "prisma migrate reset && prisma generate && node scripts/copydb.ts"
    },
    "imports": {
        "#/*": "./src/*"
    },
    "dependencies": {
        "@js-temporal/polyfill": "0.5.1",
        "@prisma/adapter-pg": "7.5.0",
        "@prisma/client": "7.5.0",
        "cors": "2.8.6",
        "discord.js": "14.25.1",
        "express": "5.2.1",
        "jose": "6.2.1",
        "luxon": "3.7.2",
        "neverthrow": "8.2.0",
        "pg": "8.20.0",
        "pino": "10.3.1",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "9.39.4",
        "@eslint/json": "1.1.0",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/luxon": "3.7.1",
        "@types/node": "25.5.0",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import": "2.32.0",
        "globals": "17.4.0",
        "pino-pretty": "13.1.3",
        "prisma": "7.5.0",
        "typescript": "6.0.1-rc",
        "typescript-eslint": "8.56.1"
    },
    "engines": {
        "node": ">=22.21"
    },
    "overrides": {
        "typescript": "6.0.1-rc",
        "undici": "6.24.0",
        "lodash": "4.17.23",
        "hono": "4.12.7",
        "@hono/node-server": "1.19.11"
    }
}
